{
  "name": "my-store",
  "version": "0.1.0",
  "private": true,

  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",

    "prisma:generate": "prisma generate --schema=db/schema.prisma",
    "prisma:migrate": "prisma migrate dev --name init --schema=db/schema.prisma --migrations=db/migrations",
    "prisma:deploy": "prisma migrate deploy --schema=db/schema.prisma",
    "prisma:push": "prisma db push --schema=db/schema.prisma",
    "prisma:studio": "prisma studio --schema=db/schema.prisma",

    "seed": "node db/seed.js"
  },

  "dependencies": {
    "@prisma/client": "^6.19.3",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },

  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4"
  }
}